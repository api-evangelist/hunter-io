{
  "opencollection": "1.0.0",
  "info": {
    "name": "Hunter Account API",
    "version": "v2"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "api_key",
      "value": "{{api_key}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Account",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Hunter Get Account",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.hunter.io/v2/account",
            "params": [
              {
                "name": "api_key",
                "value": "",
                "type": "query",
                "description": "Your Hunter API key."
              }
            ]
          },
          "docs": "Returns the authenticated account's plan, reset date, team id, and a `requests` block with `used`/`available` counters for credits, searches, and verifications.\n"
        }
      ]
    }
  ],
  "bundled": true
}