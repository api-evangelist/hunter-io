          "name": "Hunter Count Emails For Domain",
          "request": {
            "name": "Hunter Count Emails For Domain",
            "description": {
              "content": "Returns the total number of email addresses found by Hunter for a domain or a company, with breakdowns by department and seniority. No API key required; no credit consumed.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "email-count"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "domain",
                  "value": "<string>",
                  "description": "Domain name to count emails for."
                },
                {
                  "disabled": false,
                  "key": "company",
                  "value": "<string>",
                  "description": "Company name (used when domain not provided)."
                },
                {
                  "disabled": false,
                  "key": "type",
                  "value": "<string>",
                  "description": "Limit to personal or generic emails."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
