      },
      "item": [
        {
          "id": "3b54e5c1-b683-42ef-8e0c-a86bfac2af3e",
          "name": "Hunter Search Domain Emails",
          "request": {
            "name": "Hunter Search Domain Emails",
            "description": {
              "content": "Search for all email addresses corresponding to a given domain or company, including the discovered email pattern, organization metadata, and per-email confidence scores and verification status.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "domain-search"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "domain",
                  "value": "<string>",
                  "description": "The domain name from which you want to find email addresses."
                },
                {
                  "disabled": false,
                  "key": "company",
                  "value": "<string>",
                  "description": "The company name from which you want to find email addresses."
                },
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "10",
                  "description": "Maximum number of email addresses returned (1-100, default 10)."
                },
                {
                  "disabled": false,
                  "key": "offset",
                  "value": "0",
                  "description": "The number of email addresses to skip."
                },
                {
                  "disabled": false,
                  "key": "type",
                  "value": "<string>",
                  "description": "Restrict to personal or generic email addresses."
                },
                {
                  "disabled": false,
                  "key": "seniority",
                  "value": "<string>",
                  "description": "Comma-separated seniority levels (junior, senior, executive)."
                },
                {
                  "disabled": false,
                  "key": "department",
                  "value": "<string>",
                  "description": "Comma-separated departments (executive, it, finance, management, sales, legal, support, hr, marketing, communication, education, design, health, operations)."
                },
                {
                  "disabled": false,
                  "key": "required_field",
                  "value": "<string>",
                  "description": "Comma-separated list of fields that must be present in each returned email."
                },
                {
                  "disabled": false,
                  "key": "api_key",
                  "value": "<string>",
                  "description": "(Required) Your Hunter API key."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
