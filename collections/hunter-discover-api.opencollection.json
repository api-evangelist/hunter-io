{
  "opencollection": "1.0.0",
  "info": {
    "name": "Hunter Discover API",
    "version": "v2"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "api_key",
      "value": "{{api_key}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Discover",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Hunter Discover Companies",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.hunter.io/v2/discover",
            "params": [
              {
                "name": "api_key",
                "value": "",
                "type": "query",
                "description": "Your Hunter API key."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Search Hunter's company database via natural-language `query` or structured filters (industry, headcount, location, technology, funding, keywords). Returns matching companies with email-count summaries so you can prioritize targets before running Domain Search.\n"
        }
      ]
    }
  ],
  "bundled": true
}