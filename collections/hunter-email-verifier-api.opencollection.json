{
  "opencollection": "1.0.0",
  "info": {
    "name": "Hunter Email Verifier API",
    "version": "v2"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "api_key",
      "value": "{{api_key}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Email Verifier",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Hunter Verify Email",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.hunter.io/v2/email-verifier",
            "params": [
              {
                "name": "email",
                "value": "",
                "type": "query",
                "description": "The email address to verify."
              },
              {
                "name": "api_key",
                "value": "",
                "type": "query",
                "description": "Your Hunter API key."
              }
            ]
          },
          "docs": "Verifies an email address against MX, SMTP, regex, gibberish, disposable, webmail, accept-all, block, and Hunter database checks. Returns a status, score, and supporting flags. Responds 202 while verification is still in flight; retry the same call to get the final result.\n"
        }
      ]
    }
  ],
  "bundled": true
}