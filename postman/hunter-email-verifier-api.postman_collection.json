  "info": {
    "_postman_id": "6b6483c4-26fa-4c53-82ec-7e66213f6449",
    "name": "Hunter Email Verifier API",
    "description": "Verifies the deliverability of an email address by performing MX-record inspection, SMTP connection checks, catch-all detection, disposable domain detection, webmail detection, and Hunter's own database lookup. Returns a confidence score and a normalized status (valid, invalid, accept_all, webmail, disposable, unknown).\n\n\nContact Support:\n Name: Hunter Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
